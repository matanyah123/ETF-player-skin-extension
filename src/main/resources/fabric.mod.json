{
	"schemaVersion": 1,
	"id": "pse-etf",
	"version": "${version}",
	"name": "Player Skin Extension for ETF",
	"description": "Adds \u0024username\u0024 player-skin tokens for ETF/OptiFine-style entity texture workflows.",
	"authors": [
		"Matanyah"
	],
	"license": "CC0-1.0",
	"icon": "assets/pse-etf/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"net.matanyah.pse.PlayerSkinExtensionETF"
		]
	},
	"mixins": [
		"pse-etf.mixins.json",
		"pse-etf-compat.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"entity_texture_features": "*"
	}
}
